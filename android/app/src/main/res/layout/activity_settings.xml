<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Section: Watermark -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WATERMARK"
            android:textColor="@color/brand_pink"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Watermark"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
            <Switch
                android:id="@+id/switchSettingsWatermark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="@color/brand_pink"
                android:trackTint="@color/track_color" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Text (editable)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etSettingsWatermarkText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:hint="Your watermark text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <!-- Logo lock notice -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="28dp"
            android:alpha="0.6">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌸 OtoHana Logo"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 Always On"
                android:textColor="@color/brand_pink"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Section: Recording -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RECORDING"
            android:textColor="@color/brand_pink"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Video Bitrate"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerSettingsBitrate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio Mode"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerSettingsAudio"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="28dp" />

        <!-- Save button -->
        <Button
            android:id="@+id/btnSettingsSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/brand_pink"
            android:layout_marginBottom="24dp" />

        <!-- App version -->
        <TextView
            android:id="@+id/tvSettingsVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:alpha="0.5" />

    </LinearLayout>
</ScrollView>
